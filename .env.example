# ============================================================================
# JobRadar environment variables. Copy to .env.local for local dev.
# Each var lives in exactly ONE place in production (see README / spec §10).
# ============================================================================

# --- Supabase (Vercel Project Env) ------------------------------------------
# Browser-safe (RLS protects the data). Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used ONLY by lib/supabase/admin.ts. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# --- Access-code gate (Vercel Project Env) ----------------------------------
# The code you type to unlock the dashboard. Checked server-side; never shipped
# to the browser. Change it any time.
ACCESS_CODE=280902
# Secret used to sign the access cookie (any long random string). If unset it
# falls back to SUPABASE_SERVICE_ROLE_KEY, but setting it explicitly is better.
GATE_SECRET=

# --- Data owner (Vercel Project Env + GitHub Actions) -----------------------
# The auth.users UUID the scraper stamps rows with, and the app reads under.
# Create one Supabase auth user (Dashboard -> Authentication -> Add user) and
# paste its UUID here. No password/email login is used — the access code is.
OWNER_USER_ID=

# --- Manual "refresh now" -> GitHub Actions (Vercel Project Env) -------------
# Fine-grained PAT scoped to this repo with Actions read/write.
GH_DISPATCH_TOKEN=
GH_REPO=your-username/jobradar

# --- Portfolio link (Vercel Project Env, browser-safe) ----------------------
NEXT_PUBLIC_PORTFOLIO_URL=https://vineeth-portfolio-five.vercel.app/#work

# ============================================================================
# The following live in GITHUB ACTIONS SECRETS, not Vercel. Listed here for
# completeness only — do not put them in .env.local unless running the scraper
# locally.
# ============================================================================
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# OWNER_USER_ID=
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
# ANTHROPIC_API_KEY=            # OPTIONAL — leave UNSET for the $0 default
# USE_LLM_RATIONALE=false       # OPTIONAL — default false
